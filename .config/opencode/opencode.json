{
  "$schema": "https://opencode.ai/config.json",
  "lsp": {
    "bash": {
      "command": ["bash-language-server", "start"],
      "extensions": [".sh", ".bash"]
    }
  },
  "autoupdate": true,
  "permission": {
    "external_directory": "allow",

    "bash": {
      "git push": "deny",
      "git push *": "deny",
      "sudo *": "deny",
      "rm -rf /": "deny",
      "rm -rf /*": "deny",
      "rm -rf ~": "deny",
      "rm -rf ~/*": "deny",
      ":(){:|:&};:": "deny"
    }
  },

  "plugin": []
}
